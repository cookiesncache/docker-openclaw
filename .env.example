# Copy to .env and fill in. Never commit the real .env.
# Generate a token, e.g.: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=changeme-generate-a-random-token
ANTHROPIC_API_KEY=sk-ant-...
TZ=America/New_York
# Auth over plain HTTP. Default true for direct LAN-HTTP access; set false (recommended) behind a
# TLS terminator (Tailscale serve / reverse proxy), opening the UI via its https URL.
OPENCLAW_ALLOW_INSECURE_AUTH=true

# Control UI allowed origins (CSRF protection) - set to the URL you reach the UI from,
# e.g. https://openclaw.YOUR-TAILNET.ts.net  (comma-separated for multiple). Recommended.
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=

# Optional extra provider keys / bot tokens (uncomment + set if used):
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#GEMINI_API_KEY=
#GROQ_API_KEY=
#XAI_API_KEY=
#ZAI_API_KEY=
#COPILOT_GITHUB_TOKEN=
#DISCORD_BOT_TOKEN=
#TELEGRAM_BOT_TOKEN=
#BRAVE_API_KEY=
