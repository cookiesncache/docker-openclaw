# Copy to .env and fill in. Never commit the real .env.
# Generate a token, e.g.: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=changeme-generate-a-random-token
ANTHROPIC_API_KEY=sk-ant-...
TZ=America/New_York
# Default true: gateway runs HTTP behind a TLS terminator (Tailscale serve / reverse proxy).
# Set false only to require HTTPS at the gateway itself.
OPENCLAW_ALLOW_INSECURE_AUTH=true

# Optional extra provider keys / bot tokens (uncomment + set if used):
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
#GEMINI_API_KEY=
#GROQ_API_KEY=
#XAI_API_KEY=
#ZAI_API_KEY=
#COPILOT_GITHUB_TOKEN=
#DISCORD_BOT_TOKEN=
#TELEGRAM_BOT_TOKEN=
#BRAVE_API_KEY=
