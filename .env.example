# Copy to .env and fill in. Never commit the real .env.
# Generate a token, e.g.: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=changeme-generate-a-random-token
ANTHROPIC_API_KEY=sk-ant-...
TZ=America/New_York
# Set true only for plain-HTTP LAN access (default false = HTTPS/secure auth).
OPENCLAW_ALLOW_INSECURE_AUTH=false
