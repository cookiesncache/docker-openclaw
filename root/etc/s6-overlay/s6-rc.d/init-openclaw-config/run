#!/usr/bin/with-contenv bash

# Ensure the config/state/workspace tree exists on the /config volume.
# HOME=/config, so OpenClaw resolves ~/.openclaw to /config/.openclaw.
mkdir -p \
    /config/.openclaw/state \
    /config/.openclaw/workspace

# Seed the default gateway config on first run, from /defaults (LSIO idiom).
if [[ ! -f /config/.openclaw/openclaw.json ]]; then
    echo "**** first run: seeding default openclaw.json from /defaults ****"
    cp /defaults/openclaw.json /config/.openclaw/openclaw.json
fi

# Apply security-relevant Control UI / auth config each boot. Env-driven settings stay
# authoritative; the rate-limit default is only seeded when absent (never overrides yours).
#   OPENCLAW_ALLOW_INSECURE_AUTH         accept auth over plain HTTP. Default true for direct
#                                        LAN-HTTP access; set false (recommended) behind a TLS
#                                        terminator (Tailscale serve / reverse proxy), reaching
#                                        the UI via its https/wss URL.
#   OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS  comma-separated allowed origins for the Control UI
#                                        (CSRF/origin protection on a non-loopback bind), e.g.
#                                        https://openclaw.<tailnet>.ts.net
echo "**** applying control-UI/auth config (insecureAuth=${OPENCLAW_ALLOW_INSECURE_AUTH:-true}) ****"
node -e '
  const fs = require("fs"), p = "/config/.openclaw/openclaw.json";
  try {
    const c = JSON.parse(fs.readFileSync(p, "utf8"));
    c.gateway = c.gateway || {};
    const ui = c.gateway.controlUi = c.gateway.controlUi || {};
    const auth = c.gateway.auth = c.gateway.auth || {};

    // allowInsecureAuth: env-authoritative, default true
    const raw = (process.env.OPENCLAW_ALLOW_INSECURE_AUTH ?? "true").toLowerCase();
    ui.allowInsecureAuth = !["false","0","no","off"].includes(raw);

    // allowedOrigins: set only when provided (comma-separated)
    const origins = (process.env.OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS || "")
      .split(",").map(s => s.trim()).filter(Boolean);
    if (origins.length) ui.allowedOrigins = origins;

    // auth.rateLimit: seed a sane default if unset; never override a user-set value
    if (auth.rateLimit == null) {
      auth.rateLimit = { maxAttempts: 10, windowMs: 60000, lockoutMs: 300000 };
    }

    fs.writeFileSync(p, JSON.stringify(c));
  } catch (e) { console.log("WARN: could not patch openclaw.json: " + e.message); }
'

# Hand the tree to the runtime user (abc, remapped to PUID/PGID by the base init).
lsiown -R abc:abc /config/.openclaw
