#!/usr/bin/with-contenv bash

# Ensure the config/state/workspace tree exists on the /config volume.
# HOME=/config, so OpenClaw resolves ~/.openclaw to /config/.openclaw.
mkdir -p \
    /config/.openclaw/state \
    /config/.openclaw/workspace

# Seed the default gateway config on first run, from /defaults (LSIO idiom).
if [[ ! -f /config/.openclaw/openclaw.json ]]; then
    echo "**** first run: seeding default openclaw.json from /defaults ****"
    cp /defaults/openclaw.json /config/.openclaw/openclaw.json
fi

# Auth posture is env-driven: OPENCLAW_ALLOW_INSECURE_AUTH (default TRUE). The gateway only ever
# serves plain HTTP; HTTPS comes from a front terminator (Tailscale serve / reverse proxy), where
# the real encryption lives. TRUE lets the gateway accept that loopback-proxied connection -- the
# normal, correct setting. FALSE makes it reject anything it can't see as TLS; behind a terminator
# it only sees localhost HTTP, so FALSE just breaks access (it adds no security here). Enforced
# every boot so the variable stays authoritative; all other config fields are preserved.
echo "**** applying OPENCLAW_ALLOW_INSECURE_AUTH=${OPENCLAW_ALLOW_INSECURE_AUTH:-true} ****"
node -e '
  const fs = require("fs"), p = "/config/.openclaw/openclaw.json";
  try {
    const raw = (process.env.OPENCLAW_ALLOW_INSECURE_AUTH ?? "true").toLowerCase();
    const insecure = !["false","0","no","off"].includes(raw);
    const c = JSON.parse(fs.readFileSync(p, "utf8"));
    c.gateway = c.gateway || {};
    c.gateway.controlUi = c.gateway.controlUi || {};
    c.gateway.controlUi.allowInsecureAuth = insecure;
    fs.writeFileSync(p, JSON.stringify(c));
  } catch (e) { console.log("WARN: could not patch openclaw.json: " + e.message); }
'

# Hand the tree to the runtime user (abc, remapped to PUID/PGID by the base init).
lsiown -R abc:abc /config/.openclaw
